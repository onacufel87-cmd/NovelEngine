{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "小说引擎",
  "version": "0.1.0",
  "identifier": "com.novel.reader.core",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "小说引擎 — 通用书源阅读器（免责声明：不含任何盗版内容）",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "通用书源解析引擎 + 纯净桌面阅读器",
    "longDescription": "开源 Tauri 桌面阅读器：JSON 书源规则、启发式自动检测、书架与 EPUB/TXT 导入。官方仓库不含任何第三方盗版书源。",
    "copyright": "Copyright © 2026 Novel Reader Core contributors",
    "category": "Utility",
    "resources": ["resources/*"],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": false
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "startMenuFolder": "小说引擎",
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  }
}
